{
  "name": "glc-deal-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Greenlink Capital — generate deal documents (Letter of Offer, etc.) from HubSpot data.",
  "scripts": {
    "proof": "node render.mjs canonical/example.deal.json 'Letter of Offer - proof.docx'",
    "setup:hubspot": "node hubspot/setup-properties.mjs",
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "docxtemplater": "^3.66.5",
    "pizzip": "^3.2.0",
    "decimal.js": "^10.4.3",
    "express": "^4.19.2",
    "limiter": "^2.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0"
  }
}
